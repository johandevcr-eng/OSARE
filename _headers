# Cache persistente para imágenes
/img/*
  Cache-Control: public, max-age=31536000, immutable

# Cache persistente para videos
/video/*
  Cache-Control: public, max-age=31536000, immutable

# Cache para CSS y JS
/*.css
  Cache-Control: public, max-age=31536000, immutable
/*.js
  Cache-Control: public, max-age=31536000, immutable

# HTML con cache corto para permitir actualizaciones rápidas
/*.html
  Cache-Control: public, max-age=0, must-revalidate
/
  Cache-Control: public, max-age=0, must-revalidate